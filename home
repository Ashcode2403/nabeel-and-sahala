<script>
// ─── Custom cursor ────────────────────────────────────────
const cur = document.getElementById('cursor');
const trail = document.getElementById('cursor-trail');
let mx=0,my=0,tx=0,ty=0;
document.addEventListener('mousemove',e=>{
  mx=e.clientX;my=e.clientY;
  cur.style.left=mx+'px';cur.style.top=my+'px';
});
setInterval(()=>{
  tx+=(mx-tx)*0.15;ty+=(my-ty)*0.15;
  trail.style.left=tx+'px';trail.style.top=ty+'px';
},16);

// ─── Theme toggle ─────────────────────────────────────────
function toggleTheme(){
  const d=document.documentElement;
  const btn=document.querySelector('.ctrl-btn');
  if(d.dataset.theme==='dark'){
    d.dataset.theme='light';btn.textContent='🌙 Dark';
  }else{
    d.dataset.theme='dark';btn.textContent='☀️ Light';
  }
}

// ─── Language toggle ──────────────────────────────────────
function setLang(lang){
  document.querySelectorAll('.lang-btn').forEach(b=>b.classList.remove('active'));
  document.querySelector(`.lang-btn[onclick="setLang('${lang}')"]`).classList.add('active');
  document.querySelectorAll('.en').forEach(el=>el.style.display=lang==='en'?'':'none');
  document.querySelectorAll('.ml').forEach(el=>el.style.display=lang==='ml'?'':'none');
}

// ─── Countdown ────────────────────────────────────────────
function updateCountdown(){
  const target=new Date('2026-05-31T10:00:00');
  const now=new Date();
  const diff=target-now;
  if(diff<=0){['days','hours','mins','secs'].forEach(id=>document.getElementById(id).textContent='0');return;}
  const d=Math.floor(diff/86400000);
  const h=Math.floor((diff%86400000)/3600000);
  const m=Math.floor((diff%3600000)/60000);
  const s=Math.floor((diff%60000)/1000);
  const set=(id,val)=>{
    const el=document.getElementById(id);
    const newVal=String(val).padStart(2,'0');
    if(el.textContent!==newVal){
      el.classList.add('flip');
      setTimeout(()=>{el.textContent=newVal;el.classList.remove('flip');},100);
    }
  };
  set('days',d);set('hours',h);set('mins',m);set('secs',s);
}
updateCountdown();setInterval(updateCountdown,1000);

// ─── Scroll reveal ────────────────────────────────────────
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');});
},{threshold:0.12});
document.querySelectorAll('[data-reveal]').forEach(el=>obs.observe(el));

// ─── Petal rain ───────────────────────────────────────────
const petalCanvas=document.getElementById('petal-canvas');
const colors=['#f0c4c4','#f5d5d5','#c8d8c0','#e8d5b0','#f0d5e0','#dde8d8','#e8c8e0'];
function makePetal(){
  const el=document.createElement('div');
  Object.assign(el.style,{
    position:'absolute',top:'-60px',opacity:'0',
    left:Math.random()*100+'%',
    animation:`petalFall ${6+Math.random()*8}s ${Math.random()*6}s linear forwards`
  });
  const sz=10+Math.random()*14;
  const col=colors[Math.floor(Math.random()*colors.length)];
  const rot=Math.random()*360;
  el.innerHTML=`<svg width="${sz}" height="${sz}" viewBox="0 0 20 20"><ellipse cx="10" cy="10" rx="5" ry="10" fill="${col}" opacity="0.75" transform="rotate(${rot},10,10)"/></svg>`;
  petalCanvas.appendChild(el);
  setTimeout(()=>el.remove(),(14+6)*1000);
}
const style=document.createElement('style');
style.textContent=`@keyframes petalFall{0%{transform:translateY(0) rotate(0deg);opacity:0}10%{opacity:.7}90%{opacity:.4}100%{transform:translateY(110vh) rotate(360deg);opacity:0}}`;
document.head.appendChild(style);
for(let i=0;i<20;i++)setTimeout(makePetal,i*500);
setInterval(makePetal,700);

// ─── Confetti burst on load ───────────────────────────────
const ccv=document.getElementById('confetti-canvas');
const ctx2=ccv.getContext('2d');
ccv.width=window.innerWidth;ccv.height=window.innerHeight;
const confetti=[];
const confColors=['#f0c4c4','#c8d8c0','#b8922a','#c97070','#e8d5b0','#f5d5d5'];
for(let i=0;i<120;i++){
  confetti.push({
    x:Math.random()*ccv.width,
    y:Math.random()*ccv.height-ccv.height,
    r:Math.random()*6+2,
    d:Math.random()*3+1,
    color:confColors[Math.floor(Math.random()*confColors.length)],
    tilt:Math.random()*10-5,speed:Math.random()*3+1,
    opacity:1
  });
}
let confettiActive=true;
function drawConfetti(){
  if(!confettiActive)return;
  ctx2.clearRect(0,0,ccv.width,ccv.height);
  confetti.forEach(c=>{
    ctx2.save();
    ctx2.globalAlpha=c.opacity;
    ctx2.fillStyle=c.color;
    ctx2.beginPath();
    ctx2.ellipse(c.x,c.y,c.r,c.r*0.4,c.tilt,0,Math.PI*2);
    ctx2.fill();
    ctx2.restore();
    c.y+=c.speed;c.x+=Math.sin(c.d)*2;
    c.tilt+=0.1;c.opacity-=0.003;
    if(c.y>ccv.height)c.opacity=0;
  });
  if(confetti.every(c=>c.opacity<=0)){confettiActive=false;ctx2.clearRect(0,0,ccv.width,ccv.height);}
  else requestAnimationFrame(drawConfetti);
}
setTimeout(drawConfetti,800);

// ─── Music (Web Audio tone) ───────────────────────────────
let audioCtx=null,gainNode=null,oscillators=[];
let musicPlaying=false;
function toggleMusic(){
  const btn=document.getElementById('music-btn');
  if(!audioCtx)audioCtx=new(window.AudioContext||window.webkitAudioContext)();
  if(musicPlaying){
    oscillators.forEach(o=>{try{o.stop();}catch(e){}});
    oscillators=[];
    btn.classList.remove('playing');btn.textContent='♪';
    musicPlaying=false;
  }else{
    gainNode=audioCtx.createGain();
    gainNode.gain.setValueAtTime(0.06,audioCtx.currentTime);
    gainNode.connect(audioCtx.destination);
    // Gentle soft drone - peaceful nasheed-like tones
    [[261.63,0],[329.63,0.3],[392,0.6],[523.25,1]].forEach(([freq,delay],i)=>{
      const osc=audioCtx.createOscillator();
      const g2=audioCtx.createGain();
      osc.type='sine';osc.frequency.value=freq;
      g2.gain.setValueAtTime(0,audioCtx.currentTime+delay);
      g2.gain.linearRampToValueAtTime(0.3,audioCtx.currentTime+delay+0.5);
      osc.connect(g2);g2.connect(gainNode);
      osc.start(audioCtx.currentTime+delay);
      oscillators.push(osc);
    });
    btn.classList.add('playing');btn.textContent='♫';
    musicPlaying=true;
  }
}

