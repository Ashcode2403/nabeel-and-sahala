<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nabeel & Shahalasin – Nikah Invitation</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Cinzel:wght@400;500;600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
<style>
:root {
  --rose: #f0c4c4;
  --rose-deep: #c97070;
  --blush: #fbeaea;
  --sage: #c8d8c0;
  --sage-deep: #7a9e72;
  --cream: #fdf8f2;
  --gold: #b8922a;
  --gold-light: #e2cfa0;
  --gold-glow: #f0deb0;
  --mauve: #b08898;
  --text-dark: #3a2832;
  --text-mid: #6a4858;
  --text-light: #9a7888;
  --card-bg: #ffffff;
  --card-border: #e8d5b5;
  --section-bg: #fdf4ee;
  --overlay: rgba(253,248,242,0.95);
}
[data-theme="dark"] {
  --rose: #7a3a3a;
  --rose-deep: #c97070;
  --blush: #2a1818;
  --sage: #2a3a28;
  --sage-deep: #7a9e72;
  --cream: #1a1210;
  --gold: #c9a96e;
  --gold-light: #5a4020;
  --gold-glow: #3a2a10;
  --mauve: #806070;
  --text-dark: #f0e0d0;
  --text-mid: #c0a090;
  --text-light: #907870;
  --card-bg: #221818;
  --card-border: #5a3a28;
  --section-bg: #1e1410;
  --overlay: rgba(26,18,16,0.95);
}

*{margin:0;padding:0;box-sizing:border-box;}

html{scroll-behavior:smooth;}

body{
  background:var(--cream);
  font-family:'Lato',sans-serif;
  color:var(--text-dark);
  overflow-x:hidden;
  cursor:none;
  transition:background 0.5s,color 0.5s;
}

/* Custom cursor */
.cursor{
  position:fixed;width:16px;height:16px;
  background:var(--rose-deep);border-radius:50%;
  pointer-events:none;z-index:9999;
  transform:translate(-50%,-50%);
  transition:transform 0.1s,opacity 0.3s;
  mix-blend-mode:multiply;
}
[data-theme="dark"] .cursor{mix-blend-mode:screen;}
.cursor-trail{
  position:fixed;width:6px;height:6px;
  background:var(--gold);border-radius:50%;
  pointer-events:none;z-index:9998;
  transform:translate(-50%,-50%);
  opacity:0.5;
  transition:transform 0.3s,opacity 0.3s;
}

/* Petal canvas */
#petal-canvas{
  position:fixed;top:0;left:0;width:100%;height:100%;
  pointer-events:none;z-index:1;overflow:hidden;
}

/* Confetti */
#confetti-canvas{
  position:fixed;top:0;left:0;width:100%;height:100%;
  pointer-events:none;z-index:1000;
}

/* Controls bar */
.controls-bar{
  position:fixed;top:16px;right:16px;z-index:500;
  display:flex;gap:8px;flex-direction:column;align-items:flex-end;
}
.ctrl-btn{
  background:var(--card-bg);border:1px solid var(--card-border);
  border-radius:50px;padding:8px 14px;
  font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.15em;
  color:var(--text-mid);cursor:pointer;
  transition:all 0.3s;box-shadow:0 2px 12px rgba(0,0,0,0.08);
  display:flex;align-items:center;gap:6px;
}
.ctrl-btn:hover{background:var(--rose-deep);color:#fff;border-color:var(--rose-deep);}

/* Print btn */
.print-btn{
  background:var(--gold);color:#fff;border:none;
  border-radius:50px;padding:8px 16px;
  font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.15em;
  cursor:pointer;transition:all 0.3s;
}
.print-btn:hover{opacity:0.85;}

/* Lang toggle */
.lang-toggle{
  display:flex;gap:4px;background:var(--card-bg);
  border:1px solid var(--card-border);border-radius:50px;padding:4px;
  box-shadow:0 2px 12px rgba(0,0,0,0.08);
}
.lang-btn{
  padding:5px 12px;border-radius:50px;border:none;
  font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.1em;
  cursor:pointer;transition:all 0.3s;
  background:transparent;color:var(--text-light);
}
.lang-btn.active{background:var(--rose-deep);color:#fff;}

/* Music btn */
.music-btn{
  width:40px;height:40px;border-radius:50%;
  background:var(--card-bg);border:1px solid var(--card-border);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;transition:all 0.3s;
  box-shadow:0 2px 12px rgba(0,0,0,0.08);
  color:var(--text-mid);font-size:16px;
}
.music-btn.playing{background:var(--rose-deep);color:#fff;border-color:var(--rose-deep);}
.music-btn.playing{animation:pulse-ring 2s infinite;}
@keyframes pulse-ring{
  0%{box-shadow:0 0 0 0 rgba(201,112,112,0.4);}
  70%{box-shadow:0 0 0 12px rgba(201,112,112,0);}
  100%{box-shadow:0 0 0 0 rgba(201,112,112,0);}
}

/* Page layout */
.page{
  position:relative;z-index:2;
  max-width:720px;margin:0 auto;
  padding:20px 16px 80px;
}

/* Parallax hero */
.hero{
  position:relative;overflow:hidden;
  border-radius:28px 28px 0 0;
  background:linear-gradient(160deg,#fdf0f0 0%,#f8eef8 40%,#eef5ea 100%);
  padding:60px 30px 50px;
  text-align:center;
  border:1.5px solid var(--card-border);
  border-bottom:none;
}
[data-theme="dark"] .hero{
  background:linear-gradient(160deg,#2a1818 0%,#221828 40%,#182218 100%);
}

/* Animated crescent */
.crescent-wrap{
  position:absolute;top:20px;left:50%;transform:translateX(-50%);
  animation:float 4s ease-in-out infinite;
}
@keyframes float{
  0%,100%{transform:translateX(-50%) translateY(0);}
  50%{transform:translateX(-50%) translateY(-8px);}
}
.crescent-svg{filter:drop-shadow(0 4px 12px rgba(201,169,110,0.4));}

/* Lantern string */
.lanterns{
  position:absolute;top:0;left:0;width:100%;
  display:flex;justify-content:space-around;
  pointer-events:none;
}
.lantern{
  display:flex;flex-direction:column;align-items:center;
  animation:lanternSway ease-in-out infinite;
}
.lantern:nth-child(1){animation-duration:3s;animation-delay:0s;}
.lantern:nth-child(2){animation-duration:3.5s;animation-delay:0.5s;}
.lantern:nth-child(3){animation-duration:4s;animation-delay:1s;}
.lantern:nth-child(4){animation-duration:3.2s;animation-delay:1.5s;}
.lantern:nth-child(5){animation-duration:3.8s;animation-delay:0.8s;}
@keyframes lanternSway{
  0%,100%{transform:rotate(-5deg);}
  50%{transform:rotate(5deg);}
}

.bismillah{
  font-family:'Cormorant Garamond',serif;
  font-style:italic;font-size:20px;
  color:var(--gold);letter-spacing:0.08em;
  margin:50px 0 16px;
  text-shadow:0 0 20px rgba(201,169,110,0.3);
}
.wedding-label{
  font-family:'Cinzel',serif;font-size:10px;
  letter-spacing:0.4em;color:var(--text-light);
  text-transform:uppercase;margin-bottom:24px;
}
.couple-names{
  display:flex;align-items:center;justify-content:center;
  gap:20px;flex-wrap:wrap;
}
.name{
  font-family:'Cormorant Garamond',serif;
  font-size:52px;font-weight:300;
  color:var(--text-dark);line-height:1.05;
}
.name-sub{
  display:block;font-size:11px;
  font-family:'Cinzel',serif;
  letter-spacing:0.25em;color:var(--text-light);
  font-weight:400;margin-bottom:6px;
}
/* Gold shimmer */
.shimmer{
  background:linear-gradient(90deg,
    var(--text-dark) 0%,
    var(--gold) 40%,
    #f0d080 50%,
    var(--gold) 60%,
    var(--text-dark) 100%);
  background-size:200% auto;
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
  animation:shimmerAnim 3s linear infinite;
}
@keyframes shimmerAnim{
  0%{background-position:0% center;}
  100%{background-position:200% center;}
}
.ampersand{
  font-family:'Cormorant Garamond',serif;
  font-style:italic;font-size:72px;font-weight:300;
  color:var(--rose-deep);line-height:1;
  animation:heartbeat 2.5s ease-in-out infinite;
}
@keyframes heartbeat{
  0%,100%{transform:scale(1);}
  14%{transform:scale(1.12);}
  28%{transform:scale(1);}
  42%{transform:scale(1.06);}
  56%{transform:scale(1);}
}
.floral-div{
  display:flex;align-items:center;justify-content:center;
  gap:12px;margin:28px 0 0;
}
.fl-line{flex:1;max-width:100px;height:1px;}
.fl-line.l{background:linear-gradient(to right,transparent,var(--gold-light));}
.fl-line.r{background:linear-gradient(to left,transparent,var(--gold-light));}
.fl-icons{display:flex;gap:6px;align-items:center;}

/* Card sections */
.card{
  background:var(--card-bg);
  border:1.5px solid var(--card-border);
  border-top:none;
  border-radius:0 0 28px 28px;
  overflow:hidden;
  box-shadow:0 20px 80px rgba(100,50,30,0.1);
  transition:background 0.5s,border-color 0.5s;
}
.section{
  padding:44px 44px;
  border-bottom:1px solid var(--card-border);
  opacity:0;transform:translateY(24px);
  transition:opacity 0.7s,transform 0.7s;
}
.section.visible{opacity:1;transform:translateY(0);}

.section-label{
  font-family:'Cinzel',serif;font-size:9px;
  letter-spacing:0.4em;color:var(--gold);
  text-transform:uppercase;margin-bottom:12px;
  display:flex;align-items:center;gap:10px;
}
.section-label::before,.section-label::after{
  content:'';flex:1;height:1px;
  background:var(--gold-light);max-width:40px;
}

/* Date block */
.date-block{
  text-align:center;
  background:linear-gradient(135deg,var(--section-bg),var(--card-bg));
  border-radius:18px;border:1px solid var(--gold-light);
  padding:40px 30px;position:relative;overflow:hidden;
}
.date-block::after{
  content:'';position:absolute;
  width:200px;height:200px;border-radius:50%;
  background:radial-gradient(circle,var(--gold-glow),transparent);
  top:-80px;right:-60px;pointer-events:none;
}
.nikah-title{
  font-family:'Cormorant Garamond',serif;
  font-size:32px;font-weight:300;font-style:italic;
  color:var(--text-dark);margin-bottom:24px;
}
.date-row{
  display:flex;justify-content:center;gap:0;margin:16px 0;
}
.date-part{text-align:center;padding:0 24px;}
.date-part:not(:last-child){border-right:1px solid var(--gold-light);}
.date-num{
  font-family:'Cormorant Garamond',serif;
  font-size:48px;font-weight:300;
  color:var(--rose-deep);line-height:1;
}
.date-lbl{
  font-size:10px;letter-spacing:0.15em;
  color:var(--text-light);text-transform:uppercase;margin-top:4px;
}
.day-name{
  font-family:'Cormorant Garamond',serif;
  font-style:italic;font-size:16px;
  color:var(--text-light);margin-top:8px;
}

/* Countdown */
.countdown{
  display:flex;justify-content:center;gap:10px;margin-top:24px;
}
.cd-box{
  background:var(--card-bg);border:1px solid var(--gold-light);
  border-radius:12px;padding:12px 16px;
  text-align:center;min-width:64px;
  transition:transform 0.3s,border-color 0.3s;
}
.cd-box:hover{transform:translateY(-4px);border-color:var(--rose-deep);}
.cd-num{
  font-family:'Cormorant Garamond',serif;
  font-size:32px;color:var(--rose-deep);
  line-height:1;display:block;
  transition:transform 0.2s;
}
.cd-num.flip{transform:rotateX(90deg);}
.cd-lbl{
  font-size:8px;letter-spacing:0.2em;
  text-transform:uppercase;color:var(--text-light);
  margin-top:4px;display:block;
}

/* Schedule / program */
.timeline{display:flex;flex-direction:column;gap:0;}
.tl-item{
  display:flex;gap:20px;position:relative;
  padding-bottom:24px;
}
.tl-item:last-child{padding-bottom:0;}
.tl-left{
  width:70px;text-align:right;flex-shrink:0;
  font-family:'Cinzel',serif;font-size:10px;
  color:var(--gold);letter-spacing:0.05em;
  padding-top:3px;
}
.tl-center{
  display:flex;flex-direction:column;align-items:center;
  flex-shrink:0;
}
.tl-dot{
  width:12px;height:12px;border-radius:50%;
  background:var(--rose-deep);border:2px solid var(--card-bg);
  box-shadow:0 0 0 2px var(--rose-deep);
  flex-shrink:0;
}
.tl-line{
  flex:1;width:1px;
  background:linear-gradient(to bottom,var(--rose-deep),var(--gold-light));
  margin-top:4px;
}
.tl-item:last-child .tl-line{display:none;}
.tl-right{padding-top:0;}
.tl-event{
  font-family:'Cormorant Garamond',serif;
  font-size:18px;font-weight:400;
  color:var(--text-dark);margin-bottom:2px;
}
.tl-desc{font-size:12px;color:var(--text-light);}

/* Location */
.loc-box{
  background:linear-gradient(135deg,var(--section-bg),var(--card-bg));
  border:1px solid var(--gold-light);border-radius:16px;
  padding:28px;text-align:center;
}
.loc-name{
  font-family:'Cormorant Garamond',serif;
  font-size:26px;font-style:italic;
  color:var(--text-dark);margin-bottom:6px;
}
.loc-sub{font-size:13px;color:var(--text-light);margin-bottom:18px;}
.btn-row{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;}
.map-btn,.wa-btn,.cal-btn{
  display:inline-flex;align-items:center;gap:6px;
  padding:10px 22px;border-radius:50px;
  font-family:'Cinzel',serif;font-size:10px;
  letter-spacing:0.15em;text-decoration:none;
  cursor:pointer;border:none;
  transition:all 0.3s;
}
.map-btn{
  background:linear-gradient(135deg,var(--rose-deep),var(--mauve));
  color:#fff;
  box-shadow:0 4px 18px rgba(201,112,112,0.3);
}
.map-btn:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(201,112,112,0.4);}
.wa-btn{
  background:linear-gradient(135deg,#25d366,#128c7e);
  color:#fff;box-shadow:0 4px 18px rgba(37,211,102,0.25);
}
.wa-btn:hover{transform:translateY(-2px);}
.cal-btn{
  background:var(--card-bg);color:var(--text-mid);
  border:1px solid var(--card-border);
}
.cal-btn:hover{background:var(--gold);color:#fff;border-color:var(--gold);}

/* Map embed */
.map-embed{
  border-radius:14px;overflow:hidden;
  border:1px solid var(--gold-light);
  margin-top:18px;height:200px;
  background:var(--section-bg);
  display:flex;align-items:center;justify-content:center;
  flex-direction:column;gap:8px;cursor:pointer;
  transition:all 0.3s;
}
.map-embed:hover{border-color:var(--rose-deep);}
.map-pin{font-size:32px;animation:bounce 2s ease-in-out infinite;}
@keyframes bounce{
  0%,100%{transform:translateY(0);}
  50%{transform:translateY(-8px);}
}
.map-lbl{font-family:'Cinzel',serif;font-size:11px;letter-spacing:0.2em;color:var(--text-light);}

/* QR */
.qr-box{
  text-align:center;padding:20px;
}
.qr-svg{
  border:8px solid var(--card-bg);
  border-radius:12px;
  box-shadow:0 4px 20px rgba(0,0,0,0.08);
}

/* Dress code */
.dress-grid{
  display:grid;grid-template-columns:1fr 1fr;
  gap:14px;
}
.dress-card{
  background:var(--section-bg);
  border:1px solid var(--gold-light);
  border-radius:14px;padding:20px;
  text-align:center;
}
.dress-swatch{
  width:50px;height:50px;border-radius:50%;
  margin:0 auto 10px;border:3px solid var(--card-bg);
  box-shadow:0 2px 12px rgba(0,0,0,0.1);
}
.dress-name{
  font-family:'Cormorant Garamond',serif;
  font-size:16px;color:var(--text-dark);margin-bottom:4px;
}
.dress-note{font-size:11px;color:var(--text-light);}

/* Families */
.family-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.family-card{
  background:var(--section-bg);
  border:1px solid var(--gold-light);
  border-radius:16px;padding:24px 20px;
}
.family-head{
  font-family:'Cinzel',serif;font-size:9px;
  letter-spacing:0.3em;color:var(--gold);
  text-transform:uppercase;margin-bottom:14px;
  padding-bottom:10px;border-bottom:1px solid var(--gold-light);
}
.family-member{margin-bottom:10px;}
.family-member:last-child{margin-bottom:0;}
.fm-name{
  font-family:'Cormorant Garamond',serif;
  font-size:16px;color:var(--text-dark);
}
.fm-role{font-size:11px;color:var(--text-light);}

/* Message */
.msg-box{
  background:linear-gradient(135deg,var(--blush),var(--section-bg));
  border:1px solid var(--gold-light);border-radius:16px;
  padding:28px;text-align:center;
}
.msg-text{
  font-family:'Cormorant Garamond',serif;
  font-style:italic;font-size:18px;
  color:var(--text-mid);line-height:1.8;
}
.msg-sig{
  font-family:'Cinzel',serif;font-size:10px;
  letter-spacing:0.2em;color:var(--gold);
  margin-top:14px;
}

/* Contact */
.contact-box{
  background:var(--section-bg);
  border:1px solid var(--gold-light);border-radius:14px;
  padding:20px;
}
.contact-item{
  display:flex;align-items:center;gap:12px;
  padding:10px 0;border-bottom:1px solid var(--gold-light);
}
.contact-item:last-child{border-bottom:none;}
.contact-icon{font-size:18px;width:32px;text-align:center;}
.contact-info{flex:1;}
.contact-name{font-size:13px;font-weight:600;color:var(--text-dark);}
.contact-num{font-size:12px;color:var(--text-light);}
.call-btn{
  padding:6px 14px;border-radius:50px;
  background:var(--rose-deep);color:#fff;
  font-size:10px;font-family:'Cinzel',serif;
  letter-spacing:0.1em;border:none;cursor:pointer;
  text-decoration:none;
}

/* Directions */
.dir-box{
  background:var(--section-bg);
  border:1px solid var(--gold-light);border-radius:14px;
  padding:20px;
}
.dir-item{
  display:flex;gap:12px;align-items:flex-start;
  padding:8px 0;
}
.dir-num{
  width:24px;height:24px;border-radius:50%;
  background:var(--rose-deep);color:#fff;
  display:flex;align-items:center;justify-content:center;
  font-size:11px;font-weight:700;flex-shrink:0;
  margin-top:1px;
}
.dir-text{font-size:13px;color:var(--text-mid);line-height:1.6;}

/* Photo gallery */
.gallery-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:8px;
}
.gallery-item{
  aspect-ratio:1;border-radius:10px;
  background:var(--section-bg);
  border:1px solid var(--gold-light);
  display:flex;align-items:center;justify-content:center;
  font-size:24px;cursor:pointer;transition:all 0.3s;
  overflow:hidden;position:relative;
}
.gallery-item:hover{transform:scale(1.03);border-color:var(--rose-deep);}
.gallery-placeholder{
  font-family:'Cinzel',serif;font-size:9px;
  letter-spacing:0.15em;color:var(--text-light);
  text-transform:uppercase;text-align:center;
  padding:10px;
}

/* Photo frame */
.photo-frame{
  border:3px solid var(--gold-light);border-radius:18px;
  background:var(--section-bg);
  display:flex;align-items:center;justify-content:center;
  padding:30px;margin-bottom:20px;
  aspect-ratio:4/3;position:relative;overflow:hidden;
}
.photo-frame::before,.photo-frame::after{
  content:'';position:absolute;
  width:60px;height:60px;border:2px solid var(--gold-light);
  opacity:0.5;
}
.photo-frame::before{top:10px;left:10px;border-right:none;border-bottom:none;border-radius:8px 0 0 0;}
.photo-frame::after{bottom:10px;right:10px;border-left:none;border-top:none;border-radius:0 0 8px 0;}
.photo-placeholder{
  text-align:center;
}
.photo-icon{font-size:48px;margin-bottom:10px;display:block;}
.photo-hint{font-family:'Cinzel',serif;font-size:9px;letter-spacing:0.25em;color:var(--text-light);text-transform:uppercase;}

/* RSVP */
.rsvp-form{display:flex;flex-direction:column;gap:14px;}
.form-group{display:flex;flex-direction:column;gap:6px;}
.form-label{
  font-family:'Cinzel',serif;font-size:9px;
  letter-spacing:0.2em;color:var(--gold);text-transform:uppercase;
}
.form-input,.form-select,.form-textarea{
  padding:12px 16px;border-radius:10px;
  border:1px solid var(--card-border);
  background:var(--section-bg);color:var(--text-dark);
  font-family:'Lato',sans-serif;font-size:14px;
  transition:border-color 0.3s;outline:none;
  width:100%;
}
.form-input:focus,.form-select:focus,.form-textarea:focus{
  border-color:var(--rose-deep);
}
.form-textarea{height:80px;resize:vertical;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.rsvp-btn{
  padding:14px;border-radius:50px;
  background:linear-gradient(135deg,var(--rose-deep),var(--mauve));
  color:#fff;border:none;cursor:pointer;
  font-family:'Cinzel',serif;font-size:12px;
  letter-spacing:0.2em;text-transform:uppercase;
  transition:all 0.3s;
  box-shadow:0 4px 20px rgba(201,112,112,0.3);
}
.rsvp-btn:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(201,112,112,0.4);}
.rsvp-success{
  display:none;text-align:center;padding:30px;
}
.rsvp-success.show{display:block;}
.rsvp-icon{font-size:48px;display:block;margin-bottom:12px;}
.rsvp-msg{
  font-family:'Cormorant Garamond',serif;
  font-style:italic;font-size:20px;color:var(--text-mid);
}

/* Footer */
.card-footer{
  background:linear-gradient(135deg,#faf0f0,#f0f5ea);
  padding:40px;text-align:center;
}
[data-theme="dark"] .card-footer{
  background:linear-gradient(135deg,#2a1818,#182218);
}
.footer-dua{
  font-family:'Cormorant Garamond',serif;
  font-style:italic;font-size:22px;
  color:var(--gold);margin-bottom:6px;
}
.footer-trans{
  font-size:12px;color:var(--text-light);
  letter-spacing:0.05em;margin-bottom:20px;
}
.footer-sep{
  display:flex;align-items:center;gap:10px;
  margin:20px 0;justify-content:center;
}
.footer-sep-line{
  width:60px;height:1px;background:var(--gold-light);
}
.footer-copy{
  font-family:'Cinzel',serif;font-size:9px;
  letter-spacing:0.2em;color:var(--text-light);
  text-transform:uppercase;
}

/* Malayalam hidden content */
.ml{display:none;}
.ml.active{display:block;}
.en{display:block;}
.en.active{display:block;}

/* Scroll reveal animation */
@keyframes fadeInUp{
  from{opacity:0;transform:translateY(30px);}
  to{opacity:1;transform:translateY(0);}
}

/* Print styles */
@media print{
  .controls-bar,.ctrl-btn,.music-btn,.print-btn,
  #petal-canvas,#confetti-canvas,.cursor,.cursor-trail{display:none!important;}
  .section{opacity:1!important;transform:none!important;}
  body{cursor:auto;}
}

/* Mobile */
@media(max-width:500px){
  .name{font-size:38px;}
  .ampersand{font-size:56px;}
  .family-grid,.dress-grid,.form-row{grid-template-columns:1fr;}
  .section{padding:28px 20px;}
  .date-num{font-size:36px;}
  .gallery-grid{grid-template-columns:repeat(2,1fr);}
}
</style>
